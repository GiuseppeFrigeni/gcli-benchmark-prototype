{
  "$schema": "../../docs/task.schema.json",
  "id": "gemini-repo-triage-owner-selection-json",
  "title": "Return strict JSON repo triage for a Gemini CLI issues-command regression",
  "taskKind": "prompt-output",
  "suite": "gemini-core",
  "category": "debugging",
  "difficulty": "medium",
  "language": "text",
  "taxonomy": {
    "scope": "multi-file",
    "tags": [
      "repo-triage",
      "strict-output",
      "artifact-triage"
    ]
  },
  "timeoutMs": 120000,
  "problemStatementFile": "issue.md",
  "promptAddendum": "Use only ${taskDir}/fixtures/file-tree.txt, ${taskDir}/fixtures/src-commands-issues.js, and ${taskDir}/fixtures/issues-json.test.js.",
  "verification": {
    "failToPass": [
      "node \"${taskDir}/verify-json-output.js\" \"${artifactDir}/agent-stdout.txt\" \"${taskDir}/expected.json\""
    ],
    "passToPass": [
      "node \"${taskDir}/verify-fixtures.js\" \"${taskDir}/fixtures/file-tree.txt\" \"${taskDir}/fixtures/src-commands-issues.js\" \"${taskDir}/fixtures/issues-json.test.js\""
    ]
  },
  "policy": "always"
}
