{
  "$schema": "../../docs/task.schema.json",
  "id": "gemini-json-mode-regression-triage-json",
  "title": "Return strict JSON triage for a Gemini CLI models JSON regression",
  "taskKind": "prompt-output",
  "suite": "gemini-core",
  "category": "debugging",
  "difficulty": "medium",
  "language": "text",
  "taxonomy": {
    "scope": "multi-file",
    "tags": [
      "output-format",
      "strict-output",
      "regression-reporting"
    ]
  },
  "timeoutMs": 120000,
  "problemStatementFile": "issue.md",
  "promptAddendum": "Use only ${taskDir}/fixtures/models-json-output.txt, ${taskDir}/fixtures/render-models.js, and ${taskDir}/fixtures/models-json.test.js.",
  "verification": {
    "failToPass": [
      "node \"${taskDir}/verify-json-output.js\" \"${artifactDir}/agent-stdout.txt\" \"${taskDir}/expected.json\""
    ],
    "passToPass": [
      "node \"${taskDir}/verify-fixtures.js\" \"${taskDir}/fixtures/models-json-output.txt\" \"${taskDir}/fixtures/render-models.js\" \"${taskDir}/fixtures/models-json.test.js\""
    ]
  },
  "policy": "always"
}
